#: ../userguides/forest_model.rst:2 ef8a0d2d657b47868521384a8ac52da2
msgid "🌲 Forest and trees"
msgstr ""

#: ../userguides/forest_model.rst:4 f0740c1749ef4e9aa9c8cc03e2da5192
msgid ""
"The model is trained on high-resolution data (0.6-0.3m) for different "
"areas and climate zones."
msgstr ""

#: ../userguides/forest_model.rst:6 d9a50d10aaac4bd988df1a6cae358bc4
msgid ""
"The result includes all areas covered with tree and shrub vegetation, "
"including sparse forest and shrublands."
msgstr ""

#: ../userguides/forest_model.rst:8 08c47df95b294bf1ad3976857cb34411
msgid ""
"Model resolution allows to detect small group of trees and narrow tree "
"lines."
msgstr ""

#: ../userguides/forest_model.rst:10 6a1f1a6ddbc0452b9670e3a69ac5b382
msgid ""
"The model is robust to region change, and performs well in most "
"environments, including urban. The image should be taken in active "
"vegetation period, because leafless trees or vegetation covered with snow"
" are not the target class."
msgstr ""

#: ../userguides/forest_model.rst:19 d72ec374a73f46da97846ed2da8a5d30
msgid "Processing result of forest model"
msgstr ""

#: ../userguides/forest_model.rst:19 15d721d39b874a61814f8042e4252ab5
msgid "Sample of processing results for solid **Forest** mask"
msgstr ""

#: ../userguides/forest_model.rst:21 62322a73ee3f4624b2d9c0149e8328ab
msgid "**Additional options:**"
msgstr ""

#: ../userguides/forest_model.rst:23 4f52ac1affd04b63b9ca54ceb1d30af5
msgid "*Height estimation* – forest mask classification by height classes"
msgstr ""

#: ../userguides/forest_model.rst:24 e57aa913cd344b558b7b2740f92ffd43
msgid ""
"*Tree crown polygons* - extracts tree crowns from forest vegetation as "
"well as free-standing trees, provides them as polygons"
msgstr ""

#: ../userguides/forest_model.rst:25 e57aa913cd344b558b7b2740f92ffd43
msgid ""
"*Tree crown points* - extracts tree crowns from forest vegetation as well"
" as free-standing trees, provides them as points"
msgstr ""

#: ../userguides/forest_model.rst:28 cfe8251f13894669840a86a35f9af119
msgid ""
"We recommend using the **Tree crown** options with 0.3m resolution "
"imagery (~ 19 zoom) for the best results in case you need to detect "
"individual trees."
msgstr ""

#: ../userguides/forest_model.rst:33 4bb24d8a59ee45c69b0e9f7cbc7b5584
msgid "Forest Height classification follows the following classes:"
msgstr ""

#: ../userguides/forest_model.rst:35 ffe3be6899724649a7295cb27aaf27f0
msgid "Shrubs lower than 4 meters;"
msgstr ""

#: ../userguides/forest_model.rst:36 5bad9424ce374f42bcdb53d26fc2bd50
msgid "Forest from 4 to 10 meters high;"
msgstr ""

#: ../userguides/forest_model.rst:37 0473d5b0eb9b4e3ab3aa1fbd01e81db1
msgid "Forest more than 10 meters high;"
msgstr ""

#: ../userguides/forest_model.rst:39 1a0d3ff997e64fc590571006fe6a2e8d
msgid ""
"This classification is used as a decision support for the vegetation "
"management in powerline zones, etc. See the `professional solutions by "
"Geoalert <https://geoalert.io/solutions/power>`_. The tresholds can be "
"customized depending on the requirements."
msgstr ""

